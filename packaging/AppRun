#!/bin/sh
# AppImage entry point: use only bundled Qt/OpenCV, ignore host desktop overrides.
APPDIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

export LC_ALL=C.UTF-8
export LANG=C.UTF-8

export LD_LIBRARY_PATH="$APPDIR/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export QT_PLUGIN_PATH="$APPDIR/usr/plugins"
export QML2_IMPORT_PATH="$APPDIR/usr/qml"
export QML_IMPORT_PATH="$APPDIR/usr/qml"

# Host Wayland/Hyprland settings often break portable bundles.
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-xcb}"
export QT_QUICK_CONTROLS_STYLE=Basic
unset QT_QUICK_CONTROLS_HYPRSTYLE

exec "$APPDIR/usr/bin/pixelator" "$@"
